# 复制成 .env 并填真实值。不要把 .env 提交到 git。

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/career_rag
DB_POOL_MIN=2
DB_POOL_MAX=10

# --- DeepSeek (OpenAI 兼容) ---
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 模型名以 DeepSeek 官方文档为准，这里只是占位
DEEPSEEK_MODEL_FAST=deepseek-chat
DEEPSEEK_MODEL_PRO=deepseek-reasoner

# --- Qwen Embedding (DashScope) ---
QWEN_API_KEY=sk-xxx
QWEN_EMBED_MODEL=text-embedding-v3
# 重要：必须与 pgvector 列维度一致（schema.sql 里的 vector(N)）
EMBED_DIM=1024

# --- 并发限流 ---
LLM_MAX_CONCURRENCY=5
# 单次 LLM user prompt 的字符预算；超限时保留合法 JSON 和截断元数据
LLM_USER_PROMPT_MAX_CHARS=60000
EMBED_MAX_CONCURRENCY=8

# --- Correct dual-space retrieval ---
DUAL_SPACE_ENABLED=true
IMPLICIT_MIN_CASES=3
IMPLICIT_MAX_WEIGHT=0.30
IMPLICIT_CASE_TOP_K=20

# --- Examiner-only public explain endpoint ---
EVALUATION_CAPABILITY_ENABLED=false

# --- Privacy-safe read-only monitoring page ---
MONITORING_ENABLED=false

# --- Bounded loops ---
MAX_CLARIFICATION_LOOPS=1
MAX_RERETRIEVAL_LOOPS=1
MAX_REPAIR_LOOPS=1
